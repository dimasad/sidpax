{
    "name": "Sidpax Dev Container",
    "image": "mcr.microsoft.com/devcontainers/python:3.14",
    "postCreateCommand": "pip install -e .[devextra,test]",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.black-formatter",
                "ms-python.isort"
            ]
        }
    }
}